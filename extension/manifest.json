{
  "manifest_version": 3,
  "name": "Recall - Bookmark Tracker",
  "version": "1.0.0",
  "description": "Save bookmarks and open collections as Chrome tab groups.",
  "permissions": ["tabs", "tabGroups", "activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
